# =============================================================================
# Lakeshore vLLM Proxy - Dockerfile
# =============================================================================
# Lightweight HTTP proxy that routes requests to Lakeshore via:
# - Globus Compute (preferred)
# - SSH port forwarding (fallback)
# =============================================================================

FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
# We need the entire stream package for imports
COPY pyproject.toml uv.lock ./
COPY stream/ ./stream/

# Install Python dependencies using uv
RUN pip install --no-cache-dir uv && \
    uv pip install --system --no-cache-dir -e .

# Expose proxy port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import httpx; httpx.get('http://localhost:8001/health', timeout=5.0)" || exit 1

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PROXY_HOST=0.0.0.0
ENV PROXY_PORT=8001

# Run the proxy server
CMD ["python", "-m", "uvicorn", "stream.proxy.app:app", "--host", "0.0.0.0", "--port", "8001"]
