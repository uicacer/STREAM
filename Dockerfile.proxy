# =============================================================================
# Lakeshore vLLM Proxy - Simplified Dockerfile (reuses middleware base)
# =============================================================================
# This version reuses the existing middleware image to avoid pulling new images
# =============================================================================

FROM stream-middleware:latest

# Set working directory
WORKDIR /app

# Copy the proxy module and its dependency (middleware image was built before these existed)
COPY stream/proxy /app/stream/proxy
COPY stream/middleware/core/globus_compute_client.py /app/stream/middleware/core/globus_compute_client.py

# Expose proxy port
EXPOSE 8001

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PROXY_HOST=0.0.0.0
ENV PROXY_PORT=8001

# Run the proxy server
CMD ["python", "-m", "uvicorn", "stream.proxy.app:app", "--host", "0.0.0.0", "--port", "8001"]
