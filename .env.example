# =============================================================================
# STREAM Configuration
# Single source of truth for all service configurations
# =============================================================================

# =============================================================================
# API Keys
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LITELLM_MASTER_KEY=sk-stream-2026

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432 # Internal port within Docker network
POSTGRES_EXTERNAL_PORT=5432 # Exposed port on host machine
POSTGRES_USER=litellm_user
POSTGRES_PASSWORD=postegres_secure_password
POSTGRES_DB=litellm_db

# Constructed URLs (used by services)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================
# Ollama (Local LLM Server)
# =============================================================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_EXTERNAL_PORT=11434

# Constructed URLs
OLLAMA_URL=http://${OLLAMA_HOST}:${OLLAMA_PORT}

# Resource limits (adjust based on your hardware)
# Laptops with 16GB RAM: OLLAMA_MEMORY=4G, OLLAMA_CPUS=2.0
# Laptops with 32GB RAM: OLLAMA_MEMORY=8G, OLLAMA_CPUS=4.0
# Workstations with 64GB RAM: OLLAMA_MEMORY=16G, OLLAMA_CPUS=8.0
OLLAMA_MEMORY=8G
OLLAMA_CPUS=4.0

# =============================================================================
# LiteLLM Gateway
# =============================================================================
LITELLM_HOST=litellm
LITELLM_PORT=4000
LITELLM_EXTERNAL_PORT=4000

# Constructed URLs
LITELLM_URL=http://${LITELLM_HOST}:${LITELLM_PORT}
LITELLM_BASE_URL=http://${LITELLM_HOST}:${LITELLM_PORT}

# =============================================================================
# STREAM Middleware
# =============================================================================
MIDDLEWARE_HOST=middleware
MIDDLEWARE_PORT=5000 # Internal port within Docker network
MIDDLEWARE_EXTERNAL_PORT=5000 # Exposed port on host machine

# Constructed URLs
MIDDLEWARE_URL=http://${MIDDLEWARE_HOST}:${MIDDLEWARE_PORT}

# =============================================================================
# Streamlit Frontend
# =============================================================================
FRONTEND_HOST=frontend
FRONTEND_PORT=8501 # Internal port within Docker network
FRONTEND_EXTERNAL_PORT=8501 # Exposed port on host machine

# =============================================================================
# Lakeshore vLLM (Campus HPC) - Connection Configuration
# =============================================================================
# Two connection modes supported:
# 1. Globus Compute (RECOMMENDED): Submit inference jobs remotely via Globus
# 2. SSH Port Forwarding (LEGACY): Direct connection via SSH tunnel

# --- LAKESHORE PROXY SERVICE ---
# The proxy service handles routing to Lakeshore (via Globus or SSH)
# Default values work for standard Docker setup
LAKESHORE_PROXY_HOST=lakeshore-proxy
LAKESHORE_PROXY_PORT=8001

# --- MODE SELECTION ---
# Set to "true" to use Globus Compute, "false" to use SSH port forwarding
USE_GLOBUS_COMPUTE=true

# --- GLOBUS COMPUTE CONFIGURATION (when USE_GLOBUS_COMPUTE=true) ---
# Get your endpoint ID by running: globus-compute-endpoint list
# Example: 8d978809-eec4-413d-bbd4-b099e488100a
GLOBUS_COMPUTE_ENDPOINT_ID=your-globus-endpoint-id-here

# vLLM server URL *on the Lakeshore cluster* (not localhost!)
# This is the URL that the remote Globus Compute function will use
# Examples:
#   - http://ga-001:8000 (if vLLM runs on ga-001 node)
#   - http://localhost:8000 (if vLLM runs on the compute node itself)
VLLM_SERVER_URL=http://ga-001:8000

# Timeout for Globus Compute tasks (seconds)
# Increase if your models take longer to respond
GLOBUS_TASK_TIMEOUT=120

# --- WEBSOCKET RELAY (True Token Streaming) ---
# Enables real-time token streaming from Lakeshore instead of fake streaming.
# Leave empty to use fake streaming (existing behavior).
#
# IMPORTANT: This URL changes every time you start a new tunnel session!
# You must paste the fresh URL here each time you restart ngrok/localhost.run.
# In production, deploy the relay on a server with a permanent domain
# (e.g., wss://relay.stream.example.com) so the URL stays stable.
#
# How to set up (development):
#   1. Start the relay:     python -m stream.relay.server
#   2. Start a tunnel:      ssh -R 80:localhost:8765 nokey@localhost.run
#      (or use ngrok:       ngrok http 8765)
#   3. Copy the HTTPS URL from the tunnel output and paste it below.
#      (https:// is auto-converted to wss:// for WebSocket connections)
#
# Production: deploy relay on a public server with TLS, set wss:// URL directly.
RELAY_URL=

# --- SSH PORT FORWARDING CONFIGURATION (when USE_GLOBUS_COMPUTE=false) ---
# Only needed if you prefer SSH tunneling over Globus Compute
# Requires SSH tunnel: ssh -L 8000:ga-001:8000 <NetID>@lakeshore.acer.uic.edu -N
LAKESHORE_VLLM_HOST=host.docker.internal
LAKESHORE_VLLM_PORT=8000
LAKESHORE_VLLM_ENDPOINT=http://${LAKESHORE_VLLM_HOST}:${LAKESHORE_VLLM_PORT}



# Development
DEBUG=false
RELOAD=false
LOG_LEVEL=INFO

# CORS (comma-separated)
# CORS stands for Cross-Origin Resource Sharing
# it defines which origins are allowed to access the middleware API
CORS_ORIGINS=http://localhost:{FRONTEND_EXTERNAL_PORT}


# =============================================================================
# Development Overrides (Uncomment when running outside Docker)
# =============================================================================
# When running services locally (not in Docker), use these:
# POSTGRES_HOST=localhost
# OLLAMA_HOST=localhost
# LITELLM_HOST=localhost
# MIDDLEWARE_HOST=localhost
# LAKESHORE_VLLM_HOST=localhost
