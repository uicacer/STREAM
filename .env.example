# IMPORTANT: make sure to run 'scripts/sync-env.sh' to sync this file to the gateway/.env before starting the services.
# =============================================================================
# API Keys
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MASTER_KEY=sk-stream-2024

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=litellm_user
POSTGRES_PASSWORD=postegres_secure_password
POSTGRES_DB=litellm_db

# Lakeshore vLLM Endpoint
LAKESHORE_VLLM_ENDPOINT=http://localhost:8000


# =============================================================================
# Resource Limits
# =============================================================================
# Docker resource limits (adjust based on your hardware)
# Recommended:
#   - Laptops with 16GB RAM: OLLAMA_MEMORY=4G, OLLAMA_CPUS=2.0
#   - Laptops with 32GB RAM: OLLAMA_MEMORY=8G, OLLAMA_CPUS=4.0
#   - Workstations with 64GB RAM: OLLAMA_MEMORY=16G, OLLAMA_CPUS=8.0
OLLAMA_MEMORY=8G
OLLAMA_CPUS=4.0
