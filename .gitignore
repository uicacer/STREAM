# =============================================================================
# .gitignore - Files to exclude from Git repository
# =============================================================================

# Environment variables (contains API keys - NEVER commit!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs
*.log
logs/

# Docker
*.pid
*.seed
*.pid.lock

# Database
*.db
*.sqlite
*.sqlite3
postgresql_data/
postgres_data/

# Ollama models (too large for Git)
ollama_data/
.ollama/

# Temporary files
*.tmp
*.bak
*.swp
.cache/

# OS files
Thumbs.db
.DS_Store

# Backup files
*.backup

# Node.js / React
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontends/react/dist/
frontends/react/.vite/

# Unpublished poster (keep local until after publication)
docs/pearc26-stream-poster.tex
docs/reference-verification.md

# Internal/unpublished documents (kept locally, not in public repo)
docs/*.md
docs/*.tex
docs/*.bib
docs/image/

# Paper figures (committed — referenced by paper)
!docs/figure1_theta_curve.pdf
!docs/figure1_theta_curve.png
!docs/figure2_budget_routing.pdf
!docs/figure2_budget_routing.png

# Paper source (committed)
!docs/pearc26-stream-paper.tex
!docs/references.bib

# Keep compiled paper PDF excluded (submit directly, not in repo)
docs/pearc26-stream-paper.pdf

# Claude Code memory
.claude/

# Personal backup instructions (local only)
BACKUP_INSTRUCTIONS.md

# Tutorial folder (local learning, never committed)
tutorial/
Research_Directions/

# streamrelay standalone library (has its own repo: github.com/uicacer/streamrelay)
streamrelay_staging/

# Excalidraw source files
*.excalidraw

# Test results/figures (generated)
tests/results_*.json
tests/figures/

# Benchmark datasets and HuggingFace cards (large or published separately)
scripts/eval/benchmark_dataset*.json
scripts/eval/stream_routing_benchmark.json
scripts/eval/stream_routing_benchmark.jsonl

# HuggingFace cards (committed — uploaded to HF)
!scripts/eval/hf_dataset_card.md
!scripts/eval/hf_model_card.md

# Generated datasets (large, published on HuggingFace)
scripts/eval/realworld_testset.json
scripts/eval/mixed_training_dataset.json
scripts/eval/mixed_oversample_dataset.json
scripts/eval/mixed_downsample_dataset.json
scripts/eval/balanced_training_dataset.json
scripts/eval/balanced_train.jsonl

# Trained model weights (large, published on HuggingFace)
scripts/eval/models/
