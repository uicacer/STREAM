    {
      "type": "text",
      "version": 1,
      "id": "frontend-details",
      "x": 120,
      "y": 485,
      "width": 460,
      "height": 140,
      "fontSize": 14,
      "fontFamily": 1,
      "text": "🟢 MVP: Streamlit\n  • Chat interface with streaming\n  • Document upload UI\n  • Source citations display\n  • Cost tracking per query\n\n🔵 Phase 2: Enhanced UI\n  • SSO Login (Shibboleth)\n  • Usage dashboard\n  • Admin panel",
      "textAlign": "left",
      "verticalAlign": "top",
      "groupIds": ["frontend"],
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent"
    },

    {
      "type": "rectangle",
      "version": 1,
      "id": "middleware-box",
      "x": 700,
      "y": 440,
      "width": 600,
      "height": 350,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#d3f9d8",
      "fillStyle": "solid",
      "strokeWidth": 3,
