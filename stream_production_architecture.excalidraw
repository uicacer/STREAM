    },
    {
      "type": "text",
      "version": 1,
      "id": "data-layer-title",
      "x": 120,
      "y": 1090,
      "width": 510,
      "height": 25,
      "fontSize": 20,
      "fontFamily": 1,
      "text": "💾 DATA & INFRASTRUCTURE LAYER",
      "textAlign": "left",
      "verticalAlign": "top",
      "groupIds": ["data"],
      "strokeColor": "#5f3dc4",
      "backgroundColor": "transparent"
    },
    {
      "type": "text",
      "version": 1,
      "id": "data-layer-details",
      "x": 120,
      "y": 1125,
      "width": 510,
      "height": 190,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "🟢 MVP:\n  • PostgreSQL - User data, logs, cost tracking\n  • Redis - Caching, sessions, rate limits\n  • Docker Compose - Container orchestration\n\n🟡 Phase 3: Scalability\n  • NGINX Load Balancer\n  • Redis Cluster (HA)\n  • PostgreSQL Read Replicas\n  • RabbitMQ (message queue for doc processing)\n\n🟣 Phase 4: Enterprise\n  • Kubernetes (auto-scaling, self-healing)\n  • HashiCorp Vault (secrets management)\n  • Multi-region deployment",
      "textAlign": "left",
      "verticalAlign": "top",
      "groupIds": ["data"],
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent"
    },

    {
      "type": "rectangle",
      "version": 1,
      "id": "monitoring-box",
      "x": 700,
      "y": 1220,
      "width": 600,
      "height": 210,
      "strokeColor": "#c92a2a",
